{
  "name": "tongin-market-guide-vanilla",
  "private": true,
  "version": "1.0.0",
  "description": "A modern, interactive guide map for Tongin Market, as a single-file vanilla JS application.",
  "scripts": {
    "start": "echo \"Open index.html in your browser\"",
    "build:css": "tailwindcss -i input.css -o style.css",
    "watch:css": "tailwindcss -i input.css -o style.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^4.1.18"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "node-fetch": "^2.7.0"
  }
}
